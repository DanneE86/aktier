# Discord Bot Token
# Skapa på: https://discord.com/developers/applications
# 1. New Application → Bot → Reset Token → kopiera
# 2. Aktivera "Message Content Intent" under Bot-inställningar
# 3. Bjud in med: OAuth2 → URL Generator → Scopes: bot → Permissions: Send Messages, Embed Links
DISCORD_BOT_TOKEN=din-token-här

# Backend URL (default: localhost)
BACKEND_URL=http://localhost:3000
